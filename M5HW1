void q4() {
    int c;
    cout << "1 circle 2 rectangle 3 triangle 4 quit: ";
    cin >> c;

    if (c == 1) {
        double r;
        cin >> r;
        if (r < 0) cout << "bad\n";
        else cout << 3.14159*r*r << endl;
    }
    else if (c == 2) {
        double l, w;
        cin >> l >> w;
        if (l < 0 || w < 0) cout << "bad\n";
        else cout << l*w << endl;
    }
    else if (c == 3) {
        double b, h;
        cin >> b >> h;
        if (b < 0 || h < 0) cout << "bad\n";
        else cout << 0.5*b*h << endl;
    }
    else if (c != 4) {
        cout << "wrong choice\n";
    }
}

void q5() {
    double s;
    int t;

    cout << "Enter speed and time: ";
    cin >> s >> t;

    if (s < 0 || t < 1) {
        cout << "Invalid\n";
    } else {
        for (int i = 1; i <= t; i++) {
            cout << i << " " << s*i << endl;
        }
    }
}

